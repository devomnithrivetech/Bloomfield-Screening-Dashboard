# ===== Runtime =====
ENVIRONMENT=development
# option_1 = single Claude call (demo path, active now)
# option_2 = 8-agent framework (not yet wired)
ENGAGEMENT_OPTION=option_1
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:8080,http://localhost:3000

# ===== Anthropic Claude API =====
ANTHROPIC_API_KEY=sk-ant-...
# Primary model for deal analysis (e.g. claude-opus-4-7 or claude-sonnet-4-6)
CLAUDE_MODEL=claude-opus-4-7
# Fast model for lightweight tasks (e.g. summaries)
CLAUDE_FAST_MODEL=claude-sonnet-4-6

# ===== Supabase =====
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=

# ===== Gmail OAuth =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ===== AWS S3 (email attachments + generated screeners) =====
# NOTE: S3 bucket names must be lowercase and contain only letters, numbers, and hyphens.
# Example: bloomfield-email-attachments
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=bloomfield-email-attachments

# ===== Screener template =====
SCREENER_TEMPLATE_PATH=templates/bloomfield_origination_screener.xlsx
